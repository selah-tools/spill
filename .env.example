# Upstash REST API configuration used by api/feedback
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel deploy trigger (curator publishes → KV write → triggers redeploy)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Admin bearer token for curator/admin endpoints (feedback explorer, question source editor)
ADMIN_TOKEN=

# Optional local feature flags
VITE_ENABLE_AGENTATION=false
VITE_OBSERVABILITY_DEBUG=false

# Sentry error tracking (set in Vercel environment variables for production)
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=
VITE_SENTRY_RELEASE=
SENTRY_DSN=
SENTRY_ENV=
SENTRY_RELEASE=
# Set to "true" to send feedback to KV in dev/localhost
VITE_FEEDBACK_DEV=false
