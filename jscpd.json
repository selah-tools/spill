{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schemas/jscpd.schema.json",
  "threshold": 3,
  "minLines": 8,
  "minTokens": 80,
  "reporters": ["consoleFull"],
  "ignore": [
    "**/.vercel/**",
    "**/coverage/**",
    "**/dist/**",
    "**/docs/reference/**",
    "**/node_modules/**",
    "**/*.test.ts",
    "app/questions.json",
    "app/public/**",
    "app/index.html",
    ".github/**"
  ]
}
